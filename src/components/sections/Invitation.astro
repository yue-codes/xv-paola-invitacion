---
import LilyOrnament from "@components/ui/LilyOrnament.astro";
import RoseOrnament from "@components/ui/RoseOrnament.astro";
---

<section
  id="invitacion"
  class="relative z-10 flex min-h-svh flex-col items-center justify-center px-6 text-center"
  style="background: linear-gradient(to bottom, transparent 0%, var(--color-primary) 18%); margin-top: -48px;"
>
  <!-- Ornamento superior -->
  <div class="ornament reveal mb-10" aria-hidden="true">
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
    <LilyOrnament size={20} opacity={0.75} />
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
  </div>

  <!-- Etiqueta superior -->
  <div
    class="reveal mb-6 flex items-center gap-2"
    style="transition-delay: 0.1s;"
  >
    <RoseOrnament size={11} opacity={0.5} />
    <span
      class="font-body text-xs tracking-[0.3em] uppercase"
      style="color: var(--color-accent); opacity: 0.85;"
    >
      con todo nuestro amor
    </span>
    <RoseOrnament size={11} opacity={0.5} />
  </div>

  <!-- Texto parte 1 -->
  <p
    class="reveal font-body w-full text-xl leading-relaxed font-normal sm:text-2xl md:text-3xl"
    style="color: var(--color-text); transition-delay: 0.2s;"
  >
    Queremos compartir contigo la alegría de cumplir
    <br />
    <em style="color: var(--color-gold);">15 años de nuestra hermosa hija</em>
  </p>

  <!-- Nombre destacado -->
  <h2
    class="reveal font-paola my-4 text-7xl font-normal sm:text-8xl"
    style="color: #d4a017; transition-delay: 0.3s;"
  >
    Paola
  </h2>

  <!-- Texto parte 2 -->
  <p
    class="reveal font-body w-full text-xl leading-relaxed font-normal sm:text-2xl md:text-3xl"
    style="color: var(--color-text); transition-delay: 0.4s;"
  >
    y celebrar juntos este momento
    <br />
    tan especial en la vida.
  </p>

  <!-- Ornamento inferior -->
  <div
    class="ornament reveal mt-10"
    style="transition-delay: 0.45s;"
    aria-hidden="true"
  >
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
    <LilyOrnament size={20} opacity={0.75} />
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
  </div>
</section>

<style>
  .ornament {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
</style>
