---

---

<section
  id="invitacion"
  class="relative flex min-h-svh flex-col items-center justify-center px-6 text-center"
  style="background-color: var(--color-primary);"
>
  <!-- Ornamento superior -->
  <div class="ornament reveal mb-10" aria-hidden="true">
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
    <svg
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="10" cy="10" r="3" fill="var(--color-gold)" opacity="0.7"
      ></circle>
      <circle
        cx="10"
        cy="10"
        r="7"
        stroke="var(--color-gold)"
        stroke-width="0.8"
        opacity="0.3"></circle>
    </svg>
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
  </div>

  <!-- Etiqueta superior -->
  <span
    class="reveal font-body mb-6 text-xs tracking-[0.3em] uppercase"
    style="color: var(--color-accent); opacity: 0.85; transition-delay: 0.1s;"
  >
    con todo nuestro amor
  </span>

  <!-- Texto principal -->
  <p
    class="reveal font-display w-full text-xl leading-relaxed font-semibold sm:text-2xl md:text-3xl"
    style="color: var(--color-text); transition-delay: 0.2s;"
  >
    Queremos compartir contigo la alegría de cumplir
    <br />
    <em style="color: var(--color-gold);"
      >15 años de nuestra hermosa hija Paola</em
    >
    <br />
    y celebrar juntos este momento
    <br />
    tan especial en la vida de
  </p>

  <!-- Nombre destacado -->
  <h2
    class="reveal font-display mt-6 mb-4 text-4xl font-semibold sm:text-5xl"
    style="color: var(--color-text); transition-delay: 0.35s;"
  >
    Paola
    <span
      class="mt-1 block text-2xl italic sm:text-3xl"
      style="color: var(--color-gold);"
    >
      Vázquez Tlalapango
    </span>
  </h2>

  <!-- Ornamento inferior -->
  <div
    class="ornament reveal mt-10"
    style="transition-delay: 0.45s;"
    aria-hidden="true"
  >
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
    <svg
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="10" cy="10" r="3" fill="var(--color-gold)" opacity="0.7"
      ></circle>
      <circle
        cx="10"
        cy="10"
        r="7"
        stroke="var(--color-gold)"
        stroke-width="0.8"
        opacity="0.3"></circle>
    </svg>
    <div
      class="line-draw h-px w-16"
      style="background: var(--color-gold); opacity:0.5;"
    >
    </div>
  </div>
</section>

<style>
  .ornament {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
</style>
