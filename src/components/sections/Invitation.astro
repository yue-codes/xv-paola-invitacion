---
---

<section
  id="invitacion"
  class="relative min-h-svh px-6 flex flex-col items-center justify-center text-center"
  style="background-color: var(--color-primary);"
>
  <!-- Ornamento superior -->
  <div class="ornament reveal mb-10" aria-hidden="true">
    <div class="h-px w-16 line-draw" style="background: var(--color-gold); opacity:0.5;"></div>
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <circle cx="10" cy="10" r="3" fill="var(--color-gold)" opacity="0.7"/>
      <circle cx="10" cy="10" r="7" stroke="var(--color-gold)" stroke-width="0.8" opacity="0.3"/>
    </svg>
    <div class="h-px w-16 line-draw" style="background: var(--color-gold); opacity:0.5;"></div>
  </div>

  <!-- Etiqueta superior -->
  <span
    class="reveal text-xs uppercase tracking-[0.3em] font-body mb-6"
    style="color: var(--color-accent); opacity: 0.85; transition-delay: 0.1s;"
  >
    con todo nuestro amor
  </span>

  <!-- Texto principal -->
  <p
    class="reveal font-display text-xl sm:text-2xl md:text-3xl font-semibold leading-relaxed w-full"
    style="color: var(--color-text); transition-delay: 0.2s;"
  >
    Queremos compartir contigo
    <br />
    <em style="color: var(--color-gold);">la alegría de cumplir 15 años</em>
    <br />
    y celebrar juntos este momento
    <br />
    tan especial en la vida de
  </p>

  <!-- Nombre destacado -->
  <h2
    class="reveal font-display text-4xl sm:text-5xl font-semibold mt-6 mb-4"
    style="color: var(--color-text); transition-delay: 0.35s;"
  >
    Paola
    <span
      class="italic block text-2xl sm:text-3xl mt-1"
      style="color: var(--color-gold);"
    >
      Vázquez Tlalapango
    </span>
  </h2>

  <!-- Ornamento inferior -->
  <div class="ornament reveal mt-10" style="transition-delay: 0.45s;" aria-hidden="true">
    <div class="h-px w-16 line-draw" style="background: var(--color-gold); opacity:0.5;"></div>
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <circle cx="10" cy="10" r="3" fill="var(--color-gold)" opacity="0.7"/>
      <circle cx="10" cy="10" r="7" stroke="var(--color-gold)" stroke-width="0.8" opacity="0.3"/>
    </svg>
    <div class="h-px w-16 line-draw" style="background: var(--color-gold); opacity:0.5;"></div>
  </div>
</section>

<style>
  .ornament {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
</style>
