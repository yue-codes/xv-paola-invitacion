---
import LilyOrnament from "@components/ui/LilyOrnament.astro";
import FlowerOrnament from "@components/ui/FlowerOrnament.astro";
import RoseOrnament from "@components/ui/RoseOrnament.astro";
---

<section
  id="vestimenta"
  class="relative px-6 py-24"
  style="background-color: var(--color-bg-soft);"
>
  <!-- Fondo decorativo -->
  <div
    class="absolute inset-0 bg-cover bg-fixed bg-center"
    style="background-image: url('/fondo2.webp'); opacity: 0.1;"
    aria-hidden="true"
  >
  </div>

  <!-- Encabezado -->
  <div class="relative z-10 mb-14 flex flex-col items-center text-center">
    <div class="reveal mb-6 flex items-center gap-2">
      <div
        class="h-px w-8"
        style="background: linear-gradient(to right, transparent, var(--color-gold)); opacity: 0.4;"
      >
      </div>
      <FlowerOrnament size={13} opacity={0.5} />
      <LilyOrnament size={21} opacity={0.75} />
      <FlowerOrnament size={13} opacity={0.5} />
      <div
        class="h-px w-8"
        style="background: linear-gradient(to left, transparent, var(--color-gold)); opacity: 0.4;"
      >
      </div>
    </div>
    <div
      class="reveal mb-4 flex items-center gap-2"
      style="transition-delay: 0.05s;"
    >
      <RoseOrnament size={11} opacity={0.5} />
      <span
        class="font-body text-xs tracking-[0.3em] uppercase"
        style="color: var(--color-accent);"
      >
        por favor tomar en cuenta
      </span>
      <RoseOrnament size={11} opacity={0.5} />
    </div>
    <h2
      class="reveal font-display text-3xl font-normal sm:text-4xl"
      style="color: var(--color-text); transition-delay: 0.1s;"
    >
      Código de Vestimenta
    </h2>
    <p
      class="reveal font-body mt-3 max-w-xs text-sm"
      style="color: var(--color-text); transition-delay: 0.15s;"
    >
      Etiqueta formal
    </p>
    <div
      class="line-draw mt-5 h-px w-20"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    >
    </div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 mx-auto flex max-w-md flex-col gap-8">
    <!-- Colores a evitar -->
    <div
      class="reveal rounded-2xl p-7"
      style="background: var(--color-surface); border: 1px solid color-mix(in srgb, var(--color-gold) 20%, transparent);"
    >
      <p
        class="font-body mb-5 text-center text-xs font-bold tracking-[0.25em] uppercase"
        style="color: var(--color-accent);"
      >
        Evitar estos colores
      </p>
      <div class="flex justify-center gap-6">
        <!-- Rosa -->
        <div class="flex flex-col items-center gap-2">
          <div class="relative">
            <div
              class="h-14 w-14 rounded-full"
              style="background: linear-gradient(135deg, #f4a0b5, #e8607e); box-shadow: 0 2px 10px rgba(232,96,126,0.35);"
            >
            </div>
            <!-- Tachado -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div
                class="h-px w-16 rotate-45"
                style="background: rgba(80,20,20,0.55);"
              >
              </div>
            </div>
          </div>
          <span
            class="font-body text-xs tracking-wider"
            style="color: var(--color-text-dark); font-weight: 700;"
          >
            Rosa
          </span>
        </div>
        <!-- Dorado -->
        <div class="flex flex-col items-center gap-2">
          <div class="relative">
            <div
              class="h-14 w-14 rounded-full"
              style="background: linear-gradient(135deg, #e8c870, #b8892e); box-shadow: 0 2px 10px rgba(184,137,46,0.35);"
            >
            </div>
            <!-- Tachado -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div
                class="h-px w-16 rotate-45"
                style="background: rgba(60,40,0,0.55);"
              >
              </div>
            </div>
          </div>
          <span
            class="font-body text-xs tracking-wider"
            style="color: var(--color-text-dark); font-weight: 700;"
          >
            Dorado
          </span>
        </div>
      </div>
      <p
        class="font-body mt-5 text-center text-xs leading-relaxed font-bold"
        style="color: var(--color-text-dark);"
      >
        Estos tonos están reservados para la quinceañera y sus chambelanes.
      </p>
    </div>

    <!-- Nota final -->
    <div class="reveal text-center" style="transition-delay: 0.1s;">
      <p
        class="font-body text-sm leading-relaxed font-bold"
        style="color: var(--color-text-dark);"
      >
        El resto de colores son bienvenidos.<br />
        ¡Gracias por ayudarnos a hacer esta noche especial!
      </p>
    </div>
  </div>
</section>
