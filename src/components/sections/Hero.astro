---
import Countdown from "@components/ui/Countdown";
---

<section
  id="hero"
  class="relative flex h-svh min-h-150 flex-col items-center justify-center overflow-hidden"
>
  <!-- Imagen de fondo fija -->
  <div
    class="absolute inset-0 bg-cover bg-center md:bg-fixed"
    style="background-image: url('/hero.webp');"
    aria-hidden="true"
  >
    <!-- Overlay degradado -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.38) 35%, rgba(0,0,0,0.28) 65%, var(--color-primary) 100%);"
    >
    </div>
  </div>

  <!-- Contenido centrado -->
  <div class="relative z-10 flex flex-col items-center gap-6 px-6 text-center">
    <!-- Detalle decorativo superior -->
    <div class="mb-2 flex items-center gap-3">
      <div
        class="h-px w-12"
        style="background: var(--color-gold); opacity: 0.6;"
      >
      </div>
      <span
        class="font-body text-xs tracking-[0.3em] uppercase"
        style="color: rgba(255,255,255,0.88); text-shadow: 0 1px 8px rgba(0,0,0,0.5);"
      >
        mis xv años
      </span>
      <div
        class="h-px w-12"
        style="background: var(--color-gold); opacity: 0.6;"
      >
      </div>
    </div>

    <!-- Nombre animado -->
    <h1
      class="hero-name font-paola text-6xl leading-tight font-semibold sm:text-6xl md:text-7xl"
      style="color: #e8c870;"
    >
      Paola
      <br />
      <span
        class="font-paola text-4xl font-semibold italic sm:text-4xl md:text-5xl"
        style="color: #d4af87;"
      >
        Vázquez Tlalapango
      </span>
    </h1>

    <!-- Fecha -->
    <p
      class="font-body text-sm font-semibold tracking-[0.25em] uppercase"
      style="color: rgba(255,255,255,0.85); text-shadow: 0 1px 8px rgba(0,0,0,0.5);"
    >
      22 · mayo · 2026
    </p>

    <!-- Divider dorado -->
    <div
      class="h-px w-24"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    >
    </div>

    <!-- Countdown -->
    <Countdown client:load />
  </div>

  <!-- Scroll indicator -->
  <a
    href="#invitacion"
    class="scroll-btn absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2"
    aria-label="Ver invitación"
  >
    <span
      class="font-body text-[10px] tracking-widest uppercase"
      style="color: rgba(255,255,255,0.6);"
    >
      invitación
    </span>
    <div class="scroll-arrow" style="border-color: var(--color-gold);"></div>
  </a>
</section>

<style>
  /* Animación de entrada del nombre */
  .hero-name {
    animation: fadeUp 1.2s ease forwards;
    opacity: 0;
    text-shadow:
      0 2px 24px rgba(0, 0, 0, 0.55),
      0 1px 8px rgba(0, 0, 0, 0.45);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Botón scroll */
  .scroll-btn {
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .scroll-btn:hover,
  .scroll-btn:focus-visible {
    opacity: 0.8;
  }

  /* Flecha de scroll animada */
  .scroll-arrow {
    width: 10px;
    height: 10px;
    border-right: 1px solid;
    border-bottom: 1px solid;
    transform: rotate(45deg);
    animation: bounce 1.6s ease-in-out infinite;
    opacity: 0.7;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: rotate(45deg) translateY(0);
      opacity: 0.7;
    }
    50% {
      transform: rotate(45deg) translateY(5px);
      opacity: 1;
    }
  }
</style>
