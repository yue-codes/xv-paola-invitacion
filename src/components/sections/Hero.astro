---
import Countdown from "@components/ui/Countdown";
import MusicPlayer from "@components/ui/MusicPlayer";
---

<section
  id="hero"
  class="relative flex h-svh min-h-150 flex-col items-center justify-center overflow-hidden"
  style="clip-path: polygon(0 0, 100% 0, 100% calc(100% - 64px), 50% 100%, 0 calc(100% - 64px));"
>
  <!-- Imagen de fondo fija -->
  <div
    class="absolute inset-0 bg-cover bg-fixed bg-center"
    style="background-image: url('/hero.webp');"
    aria-hidden="true"
  >
    <!-- Overlay degradado -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.38) 35%, rgba(0,0,0,0.12) 72%, transparent 100%);"
    >
    </div>
  </div>

  <!-- Contenido — ocupa toda la altura con 3 zonas -->
  <div
    class="relative z-10 flex h-full w-full flex-col items-center justify-between px-6 py-16 text-center"
  >
    <!-- Zona superior: "mis xv años" -->
    <div class="flex items-center gap-3">
      <div
        class="h-px w-12"
        style="background: var(--color-gold); opacity: 0.6;"
      >
      </div>
      <span
        class="font-body text-xs tracking-[0.3em] uppercase"
        style="color: rgba(255,255,255,0.88); text-shadow: 0 1px 8px rgba(0,0,0,0.5);"
      >
        mis xv años
      </span>
      <div
        class="h-px w-12"
        style="background: var(--color-gold); opacity: 0.6;"
      >
      </div>
    </div>

    <!-- Zona central: nombre -->
    <h1
      class="hero-name font-paola text-6xl leading-none font-semibold sm:text-6xl md:text-7xl"
      style="color: #e8c870;"
    >
      Paola
      <br />
      <span
        class="font-paola text-4xl font-semibold italic sm:text-4xl md:text-5xl"
        style="color: #e8c870;"
      >
        Vázquez Tlalapango
      </span>
    </h1>

    <!-- Zona inferior: fecha + countdown + música -->
    <div class="flex flex-col items-center gap-4">
      <p
        class="font-body text-sm font-semibold tracking-[0.25em] uppercase"
        style="color: rgba(255,255,255,0.85); text-shadow: 0 1px 8px rgba(0,0,0,0.5);"
      >
        22 · mayo · 2026
      </p>
      <div
        class="h-px w-24"
        style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
      >
      </div>
      <Countdown client:load />
      <MusicPlayer client:load />
    </div>
  </div>
</section>

<style>
  /* Animación de entrada del nombre */
  .hero-name {
    animation: fadeUp 1.2s ease forwards;
    opacity: 0;
    text-shadow:
      0 2px 24px rgba(0, 0, 0, 0.55),
      0 1px 8px rgba(0, 0, 0, 0.45);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
