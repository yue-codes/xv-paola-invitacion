---
import Confirm from "@components/sections/Confirm";
---

<section
  id="confirmar"
  class="flex flex-col items-center px-6 py-24"
  style="background-color: var(--color-primary);"
>
  <!-- Encabezado -->
  <div class="mb-12 flex flex-col items-center text-center">
    <span
      class="reveal font-body mb-4 text-xs tracking-[0.3em] uppercase"
      style="color: var(--color-accent); opacity: 0.85;"
    >
      tu presencia es nuestro regalo
    </span>
    <h2
      class="reveal font-display text-3xl font-normal sm:text-4xl"
      style="color: var(--color-text); transition-delay: 0.1s;"
    >
      Confirma tu asistencia
    </h2>
    <div
      class="line-draw mt-5 h-px w-20"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    >
    </div>
    <p
      class="reveal font-body mt-6 max-w-xs text-center text-sm leading-relaxed font-normal"
      style="color: var(--color-text); opacity: 0.65; transition-delay: 0.2s;"
    >
      Por favor confírmanos tu asistencia antes del <strong
        style="color: var(--color-gold); font-weight: 400;"
        >15 de mayo de 2026</strong
      >.
    </p>
  </div>

  <!-- Formulario Preact -->
  <div class="reveal w-full" style="transition-delay: 0.3s;">
    <Confirm client:visible />
  </div>
</section>

<style>
  :global(.field) {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  :global(.field-label) {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-family: var(--font-body);
    color: var(--color-accent);
    opacity: 0.8;
  }

  :global(.field-input) {
    background: color-mix(in srgb, var(--color-gold) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-gold) 25%, transparent);
    border-radius: 8px;
    padding: 12px 14px;
    font-size: 0.95rem;
    font-family: var(--font-body);
    font-weight: 400;
    color: var(--color-text);
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
  }

  :global(.field-input::placeholder) {
    color: var(--color-text);
    opacity: 0.3;
  }

  :global(.field-input:focus) {
    border-color: var(--color-gold);
  }

  :global(.radio-option) {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    padding: 10px 14px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
  }

  :global(.radio-dot) {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: all 0.2s;
  }
</style>
