---
const photos = [
  { src: "/1.jpg", alt: "Paola - foto 1" },
  { src: "/2.jpg", alt: "Paola - foto 2" },
  { src: "/3.jpg", alt: "Paola - foto 3" },
  { src: "/4.jpg", alt: "Paola - foto 4" },
  { src: "/5.jpg", alt: "Paola - foto 5" },
  { src: "/6.jpg", alt: "Paola - foto 6" },
];
---

<section
  id="galeria"
  class="py-24 px-6"
  style="background-color: var(--color-surface);"
>
  <!-- Encabezado -->
  <div class="flex flex-col items-center text-center mb-12">
    <span
      class="text-xs uppercase tracking-[0.3em] font-body mb-4"
      style="color: var(--color-accent); opacity: 0.85;"
    >
      momentos
    </span>
    <h2
      class="font-display text-3xl sm:text-4xl font-light"
      style="color: var(--color-text);"
    >
      Galería
    </h2>
    <div
      class="h-px w-20 mt-5"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    ></div>
  </div>

  <!-- Grid: 2 cols en móvil, 3 en sm+ -->
  <!-- Patrón: foto 1 ocupa 2 cols (featured), luego grid normal -->
  <div class="gallery-grid max-w-2xl mx-auto">
    {
      photos.map((photo, i) => (
        <div
          class={`gallery-item ${i === 0 ? "featured" : ""}`}
        >
          <img
            src={photo.src}
            alt={photo.alt}
            loading={i === 0 ? "eager" : "lazy"}
            decoding="async"
          />
          <!-- Overlay dorado al hacer tap/hover -->
          <div class="gallery-overlay" aria-hidden="true" />
        </div>
      ))
    }
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto;
    gap: 6px;
  }

  /* Primera foto: ancho completo */
  .gallery-item.featured {
    grid-column: 1 / -1;
  }

  @media (min-width: 480px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    /* En 3 cols la primera ocupa las 2 primeras columnas y 2 filas */
    .gallery-item.featured {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
    border-radius: 4px;
  }

  .gallery-item.featured {
    aspect-ratio: auto; /* hereda la altura del grid */
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-gold) 15%, transparent),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  /* Hover en desktop */
  @media (hover: hover) {
    .gallery-item:hover img {
      transform: scale(1.06);
    }

    .gallery-item:hover .gallery-overlay {
      opacity: 1;
    }
  }

  /* Tap en móvil */
  .gallery-item:active img {
    transform: scale(1.04);
  }

  .gallery-item:active .gallery-overlay {
    opacity: 1;
  }
</style>
