---
import LilyOrnament from "@components/ui/LilyOrnament.astro";
import FlowerOrnament from "@components/ui/FlowerOrnament.astro";
import RoseOrnament from "@components/ui/RoseOrnament.astro";
const photos = [
  { src: "/gallery/gallery1.webp", alt: "Paola - foto 1" },
  { src: "/gallery/gallery2.webp", alt: "Paola - foto 2" },
  { src: "/gallery/gallery3.webp", alt: "Paola - foto 3" },
  { src: "/gallery/gallery4.webp", alt: "Paola - foto 4" },
  { src: "/gallery/gallery5.webp", alt: "Paola - foto 5" },
  { src: "/gallery/gallery6.webp", alt: "Paola - foto 6" },
  { src: "/gallery/gallery7.webp", alt: "Paola - foto 7" },
  { src: "/gallery/gallery8.webp", alt: "Paola - foto 8" },
  { src: "/gallery/gallery9.webp", alt: "Paola - foto 9" },
];
---

<section
  id="galeria"
  class="px-6 py-24"
  style="background-color: var(--color-surface);"
>
  <!-- Encabezado -->
  <div class="mb-12 flex flex-col items-center text-center">
    <div class="reveal mb-6 flex items-center gap-2">
      <div
        class="h-px w-8"
        style="background: linear-gradient(to right, transparent, var(--color-gold)); opacity: 0.4;"
      >
      </div>
      <FlowerOrnament size={13} opacity={0.5} />
      <LilyOrnament size={21} opacity={0.75} />
      <FlowerOrnament size={13} opacity={0.5} />
      <div
        class="h-px w-8"
        style="background: linear-gradient(to left, transparent, var(--color-gold)); opacity: 0.4;"
      >
      </div>
    </div>
    <div
      class="reveal mb-4 flex items-center gap-2"
      style="transition-delay: 0.05s;"
    >
      <RoseOrnament size={11} opacity={0.5} />
      <span
        class="font-body text-xs tracking-[0.3em] uppercase"
        style="color: var(--color-accent); opacity: 0.85;"
      >
        momentos
      </span>
      <RoseOrnament size={11} opacity={0.5} />
    </div>
    <h2
      class="reveal font-display text-3xl font-normal sm:text-4xl"
      style="color: var(--color-text); transition-delay: 0.1s;"
    >
      Galería
    </h2>
    <div
      class="line-draw mt-5 h-px w-20"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    >
    </div>
  </div>

  <!-- Grid con stagger -->
  <div class="stagger gallery-grid mx-auto max-w-2xl">
    {
      photos.map((photo, i) => (
        <div
          class={`reveal gallery-item ${i === 0 ? "featured" : ""} ${i >= 5 ? "gallery-extra" : ""}`}
          style={`transition-delay: ${i * 0.08}s`}
        >
          <a
            href={photo.src}
            class="glightbox gallery-link"
            data-gallery="galeria"
            data-desc={photo.alt}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
            />
            <div class="gallery-overlay" aria-hidden="true" />
          </a>
        </div>
      ))
    }
  </div>

  <!-- Botón "ver más" — solo visible en móvil mientras haya fotos ocultas -->
  <div class="gallery-more-wrap mt-6 flex justify-center md:hidden">
    <button
      id="gallery-more-btn"
      class="font-body inline-flex items-center gap-2 rounded-full px-6 py-2 text-xs tracking-widest uppercase transition-opacity hover:opacity-80"
      style="border: 1px solid var(--color-gold); color: var(--color-gold);"
    >
      Ver más fotos
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12 16l-6-6h12z"></path>
      </svg>
    </button>
  </div>
</section>

<script>
  import GLightbox from "glightbox";
  import "glightbox/dist/css/glightbox.css";

  GLightbox({ selector: ".glightbox", touchNavigation: true });

  const btn = document.getElementById("gallery-more-btn");
  const extras = document.querySelectorAll(".gallery-extra");

  btn?.addEventListener("click", () => {
    extras.forEach((el) => el.classList.remove("gallery-extra"));
    btn.closest(".gallery-more-wrap")?.remove();
  });
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
  }

  .gallery-item.featured {
    grid-column: 1 / -1;
  }

  @media (min-width: 480px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .gallery-item.featured {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
    border-radius: 4px;
  }

  .gallery-item.featured {
    aspect-ratio: auto;
  }

  .gallery-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-gold) 15%, transparent),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  @media (hover: hover) {
    .gallery-item:hover img {
      transform: scale(1.06);
    }

    .gallery-item:hover .gallery-overlay {
      opacity: 1;
    }
  }

  .gallery-item:active img {
    transform: scale(1.04);
  }

  .gallery-item:active .gallery-overlay {
    opacity: 1;
  }

  /* Ocultar fotos extra en móvil hasta pulsar el botón */
  @media (max-width: 767px) {
    .gallery-extra {
      display: none;
    }
  }
</style>
