---
import LilyOrnament from "@components/ui/LilyOrnament.astro";
import FlowerOrnament from "@components/ui/FlowerOrnament.astro";
import RoseOrnament from "@components/ui/RoseOrnament.astro";
---

<section
  id="regalos"
  class="px-6 py-24"
  style="background-color: var(--color-primary);"
>
  <div class="mx-auto flex max-w-md flex-col items-center text-center">
    <!-- Ornamento superior -->
    <div class="reveal mb-6 flex items-center gap-2">
      <div
        class="h-px w-8"
        style="background: linear-gradient(to right, transparent, var(--color-gold)); opacity: 0.4;"
      >
      </div>
      <FlowerOrnament size={13} opacity={0.5} />
      <LilyOrnament size={21} opacity={0.75} />
      <FlowerOrnament size={13} opacity={0.5} />
      <div
        class="h-px w-8"
        style="background: linear-gradient(to left, transparent, var(--color-gold)); opacity: 0.4;"
      >
      </div>
    </div>

    <!-- Etiqueta -->
    <div
      class="reveal mb-4 flex items-center gap-2"
      style="transition-delay: 0.05s;"
    >
      <RoseOrnament size={11} opacity={0.5} />
      <span
        class="font-body text-xs tracking-[0.3em] uppercase"
        style="color: var(--color-accent); opacity: 0.85;"
      >
        mesa de regalos
      </span>
      <RoseOrnament size={11} opacity={0.5} />
    </div>

    <!-- Título -->
    <h2
      class="reveal font-display mb-4 text-3xl font-normal sm:text-4xl"
      style="color: var(--color-text); transition-delay: 0.1s;"
    >
      Regalos
    </h2>

    <div
      class="line-draw mb-10 h-px w-20"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    >
    </div>

    <!-- Ícono -->
    <div class="reveal mb-8" style="transition-delay: 0.15s;">
      <svg
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        stroke-linecap="round"
        stroke-linejoin="round"
        style="color: var(--color-gold); opacity: 0.7;"
        aria-hidden="true"
      >
        <!-- Caja de regalo -->
        <rect x="3" y="8" width="18" height="14" rx="1"></rect>
        <path d="M3 12h18"></path>
        <path d="M12 8V22"></path>
        <!-- Lazo -->
        <path d="M12 8c0 0 -3 -5 -5 -3s0 3 5 3z"></path>
        <path d="M12 8c0 0 3 -5 5 -3s0 3 -5 3z"></path>
        <rect x="10" y="4" width="4" height="4" rx="1"></rect>
      </svg>
    </div>

    <!-- Texto principal -->
    <p
      class="reveal font-body mb-6 text-lg leading-relaxed"
      style="color: var(--color-text); transition-delay: 0.2s;"
    >
      Para nosotros el mejor regalo es
      <em style="color: var(--color-gold); font-style: italic;">tu compañía.</em
      >
    </p>

    <!-- Divider -->
    <div
      class="reveal mb-6 h-px w-12"
      style="background: var(--color-gold); opacity: 0.3; transition-delay: 0.25s;"
    >
    </div>

    <!-- Texto secundario -->
    <p
      class="reveal font-body text-sm leading-relaxed"
      style="color: var(--color-text); opacity: 0.75; transition-delay: 0.3s;"
    >
      Pero si deseas brindarnos un obsequio sorpresa o efectivo, colocaremos un <em
        style="font-style: italic;">buzón</em
      > en la recepción del salón, donde podrás depositar tus mejores deseos.
    </p>
  </div>
</section>
