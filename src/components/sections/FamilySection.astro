---
import LilyOrnament from "@components/ui/LilyOrnament.astro";
import FlowerOrnament from "@components/ui/FlowerOrnament.astro";
import RoseOrnament from "@components/ui/RoseOrnament.astro";

interface Person {
  name: string;
}

interface FamilyGroup {
  role: string;
  people: Person[];
}

const groups: FamilyGroup[] = [
  {
    role: "Padres",
    people: [
      { name: "Concepción Tlalapango" },
      { name: "Sergio Vázquez" },
    ],
  },
  {
    role: "Padrinos",
    people: [
      { name: "Isabel Alejandra Cerqueda" },
      { name: "Francisco Cruz" },
    ],
  },
];
---

<section
  id="familia"
  class="relative min-h-svh px-6 flex flex-col justify-center"
  style="background-color: var(--color-surface);"
>
  <!-- Fondo decorativo -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-fixed"
    style="background-image: url('/fondo1.webp'); opacity: 0.1;"
    aria-hidden="true"
  ></div>

  <!-- Encabezado -->
  <div class="flex flex-col items-center text-center mb-16">
    <div class="reveal flex items-center gap-2 mb-6">
      <div class="h-px w-8" style="background: linear-gradient(to right, transparent, var(--color-gold)); opacity: 0.4;"></div>
      <FlowerOrnament size={13} opacity={0.5} />
      <LilyOrnament size={21} opacity={0.75} />
      <FlowerOrnament size={13} opacity={0.5} />
      <div class="h-px w-8" style="background: linear-gradient(to left, transparent, var(--color-gold)); opacity: 0.4;"></div>
    </div>
    <div
      class="reveal flex items-center gap-2 mb-4"
      style="transition-delay: 0.05s;"
    >
      <RoseOrnament size={11} opacity={0.5} />
      <span class="text-xs uppercase tracking-[0.3em] font-body" style="color: var(--color-accent); opacity: 0.85;">
        nos acompañan
      </span>
      <RoseOrnament size={11} opacity={0.5} />
    </div>
    <h2
      class="reveal font-display text-3xl sm:text-4xl font-normal"
      style="color: var(--color-text); transition-delay: 0.1s;"
    >
      Familia y Padrinos
    </h2>
    <div
      class="line-draw h-px w-20 mt-5"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    ></div>
  </div>

  <!-- Grupos -->
  <div class="flex flex-col items-center gap-14 w-full">
    {
      groups.map((group) => (
        <div class="w-full flex flex-col items-center gap-6">
          <!-- Etiqueta del grupo -->
          <div class="reveal flex items-center gap-3 w-full">
            <div class="h-px flex-1 line-draw" style="background: var(--color-gold); opacity: 0.25;" />
            <span
              class="text-xs uppercase tracking-[0.25em] font-body px-3"
              style="color: var(--color-text);"
            >
              {group.role}
            </span>
            <div class="h-px flex-1 line-draw" style="background: var(--color-gold); opacity: 0.25;" />
          </div>

          <!-- Personas con stagger -->
          <div class="stagger flex flex-col items-center gap-3 w-full">
            {group.people.map((person) => (
              <p
                class="reveal font-display text-xl sm:text-2xl font-semibold text-center"
                style="color: var(--color-text);"
              >
                {person.name}
              </p>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
