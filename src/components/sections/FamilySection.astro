---
interface Person {
  name: string;
}

interface FamilyGroup {
  role: string;
  people: Person[];
}

const groups: FamilyGroup[] = [
  {
    role: "Padres",
    people: [
      { name: "Concepción Tlalapango" },
      { name: "Sergio Vázquez" },
    ],
  },
  {
    role: "Padrinos",
    people: [
      { name: "Isabel Alejandra Cerqueda" },
      { name: "Francisco Cruz" },
    ],
  },
];
---

<section
  id="familia"
  class="min-h-svh px-6 flex flex-col justify-center"
  style="background-color: var(--color-surface);"
>
  <!-- Encabezado -->
  <div class="flex flex-col items-center text-center mb-16">
    <span
      class="reveal text-xs uppercase tracking-[0.3em] font-body mb-4"
      style="color: var(--color-accent); opacity: 0.85;"
    >
      quienes la acompañan
    </span>
    <h2
      class="reveal font-display text-3xl sm:text-4xl font-normal"
      style="color: var(--color-text); transition-delay: 0.1s;"
    >
      Familia &amp; Padrinos
    </h2>
    <div
      class="line-draw h-px w-20 mt-5"
      style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"
    ></div>
  </div>

  <!-- Grupos -->
  <div class="flex flex-col items-center gap-14 w-full">
    {
      groups.map((group) => (
        <div class="w-full flex flex-col items-center gap-6">
          <!-- Etiqueta del grupo -->
          <div class="reveal flex items-center gap-3 w-full">
            <div class="h-px flex-1 line-draw" style="background: var(--color-gold); opacity: 0.25;" />
            <span
              class="text-xs uppercase tracking-[0.25em] font-body px-3"
              style="color: var(--color-gold); opacity: 0.8;"
            >
              {group.role}
            </span>
            <div class="h-px flex-1 line-draw" style="background: var(--color-gold); opacity: 0.25;" />
          </div>

          <!-- Personas con stagger -->
          <div class="stagger flex flex-col items-center gap-3 w-full">
            {group.people.map((person) => (
              <p
                class="reveal font-display text-xl sm:text-2xl font-normal text-center"
                style="color: var(--color-text);"
              >
                {person.name}
              </p>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
